_cmux_commands() {
    local commands; commands=(
'ping:Ping the running cmux instance' \
'identify:Show cmux instance identity (version, platform, pid)' \
'capabilities:List supported socket commands' \
'list-workspaces:List all workspaces' \
'current-workspace:Show the current workspace' \
